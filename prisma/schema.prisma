// prisma/schema.prisma
// Station Finder — Phase 1 schema
// Run: npx prisma db push && npm run db:seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// A physical point on the ground — a junction, station, or landmark
model Location {
  id          String  @id @default(uuid())
  name        String  // e.g. "Oyarifa Junction"
  latitude    Float   // GPS coordinate
  longitude   Float
  description String  // Human directions, e.g. "Stand by the pharmacy facing Madina"

  // Relations
  routesAsOrigin      Route[] @relation("Origin")
  routesAsDestination Route[] @relation("Destination")

  createdAt DateTime @default(now())
}

// A trotro route connecting two Locations
model Route {
  id            String @id @default(uuid())
  originId      String
  destinationId String
  transitType   String // "Trotro" | "Intercity Bus"
  estimatedFare Float  // In GHS
  whatToLookFor String // e.g. "Mates shouting 'Madina!'"
  durationMins  Int    // Approximate travel time

  origin      Location @relation("Origin",      fields: [originId],      references: [id])
  destination Location @relation("Destination", fields: [destinationId], references: [id])

  createdAt DateTime @default(now())
}

// Crowdsourced stop submissions from commuters via /map-it
model CrowdsourcedStop {
  id            String   @id @default(uuid())
  stopName      String   // e.g. "Teiman Borga Town"
  latitude      Float
  longitude     Float
  routeHeading  String   // raw routes text, e.g. "Madina – 1.50 GHS, Circle – 3 GHS"
  estimatedFare Float    // first fare parsed from routeHeading, 0 if not found
  submitterId   String   // anonymous device ID for spam prevention
  votes         Int      @default(1)
  status        String   @default("PENDING") // PENDING | VERIFIED | FLAGGED
  createdAt     DateTime @default(now())
}

// Every route search logged for analytics — drives "what routes to add next"
model SearchLog {
  id          String   @id @default(uuid())
  destination String
  found       Boolean
  userLat     Float?
  userLng     Float?
  createdAt   DateTime @default(now())
}

// User-submitted route quality reports (submitted from chat UI)
model Report {
  id           String   @id @default(uuid())
  destination  String
  routeSummary String
  reason       String
  createdAt    DateTime @default(now())
}

// Phase 3 model — defined now so the schema is complete, not used in Phase 1
model PartnerDriver {
  id             String   @id @default(uuid())
  driverName     String
  vehiclePlate   String
  currentRoute   String   // e.g. "Accra - Kumasi"
  nextPickupSpot String   // e.g. "Pokuase Interchange"
  estimatedTime  DateTime
  availableSeats Int

  createdAt DateTime @default(now())
}
